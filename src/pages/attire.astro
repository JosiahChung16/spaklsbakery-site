---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Attire">
  <section class="page-header">
    <div class="container">
      <span class="section-label">What to Wear</span>
      <h1>Attire</h1>
      <div class="divider">
        <div class="divider-line"></div>
        <div class="divider-diamond"></div>
        <div class="divider-line"></div>
      </div>
      <p class="header-sub">Formal</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="prose" style="text-align:center">
        <p>We kindly request formal attire for our celebration. We'd love for our guests to draw from the palette below — a collection of soft sages, warm honeys, deep teals, and earthy greens that echo the spirit of the day.</p>
      </div>

      <div class="swatch-grid">
        <div class="swatch-item"><div class="swatch-circle" style="background:#BED2BC"></div><div class="swatch-name">Sage</div></div>
        <div class="swatch-item"><div class="swatch-circle" style="background:#E4F0D8"></div><div class="swatch-name">Mist</div></div>
        <div class="swatch-item"><div class="swatch-circle" style="background:#C8BE8C"></div><div class="swatch-name">Sand</div></div>
        <div class="swatch-item"><div class="swatch-circle" style="background:#CAA869"></div><div class="swatch-name">Honey</div></div>
        <div class="swatch-item"><div class="swatch-circle" style="background:#B4924C"></div><div class="swatch-name">Gold</div></div>
        <div class="swatch-item"><div class="swatch-circle" style="background:#C08480"></div><div class="swatch-name">Blush</div></div>
        <div class="swatch-item"><div class="swatch-circle" style="background:#0F697D"></div><div class="swatch-name">Teal</div></div>
        <div class="swatch-item"><div class="swatch-circle" style="background:#485A4E"></div><div class="swatch-name">Pine</div></div>
        <div class="swatch-item"><div class="swatch-circle" style="background:#706E3F"></div><div class="swatch-name">Olive</div></div>
        <div class="swatch-item"><div class="swatch-circle" style="background:#676453"></div><div class="swatch-name">Stone</div></div>
        <div class="swatch-item"><div class="swatch-circle" style="background:#494E3C"></div><div class="swatch-name">Forest</div></div>
      </div>

      <div class="prose" style="text-align:center">
        <p>We kindly ask that guests avoid white, ivory, and black. Beyond that, wear what makes you feel wonderful.</p>
      </div>
    </div>
  </section>
</Layout>
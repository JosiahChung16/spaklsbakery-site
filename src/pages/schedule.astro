---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Schedule">
  <section class="page-header">
    <div class="container">
      <span class="section-label">The Day Of</span>
      <h1>Schedule</h1>
      <div class="divider">
        <div class="divider-line"></div>
        <div class="divider-diamond"></div>
        <div class="divider-line"></div>
      </div>
      <p class="header-sub">Sunday, March 7th, 2027 · Memphis Art Museum</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="timeline">
        <div class="timeline-item">
          <div class="timeline-time">4:30</div>
          <div class="timeline-diamond"></div>
          <div>
            <div class="timeline-event">Guests Arrive</div>
            <div class="timeline-loc">Museum entrance — please be seated by 4:50</div>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-time">5:00</div>
          <div class="timeline-diamond"></div>
          <div>
            <div class="timeline-event">Ceremony</div>
            <div class="timeline-loc">Memphis Art Museum</div>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-time">5:30</div>
          <div class="timeline-diamond"></div>
          <div>
            <div class="timeline-event">Cocktail Hour</div>
            <div class="timeline-loc">Museum Courtyard — drinks &amp; hors d'oeuvres</div>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-time">6:00</div>
          <div class="timeline-diamond"></div>
          <div>
            <div class="timeline-event">Reception &amp; Dinner</div>
            <div class="timeline-loc">The Grand Hall — seated dinner &amp; toasts</div>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-time">8:00</div>
          <div class="timeline-diamond"></div>
          <div>
            <div class="timeline-event">Dancing</div>
            <div class="timeline-loc">The Grand Hall</div>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-time">10:00</div>
          <div class="timeline-diamond"></div>
          <div>
            <div class="timeline-event">Farewell</div>
            <div class="timeline-loc">A send-off to remember</div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
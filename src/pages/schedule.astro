---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Schedule">
  <section class="page-header">
    <div class="container">
      <span class="section-label">The Day Of</span>
      <h1>Schedule</h1>
      <div class="divider">
        <div class="divider-line"></div>
        <div class="divider-diamond"></div>
        <div class="divider-line"></div>
      </div>
      <p class="header-sub">Sunday, March 7th, 2027 · Memphis Art Museum</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="timeline">
        <div class="timeline-item">
          <div class="timeline-time">12:30</div>
          <div class="timeline-diamond"></div>
          <div>
            <div class="timeline-event">Guests Arrive</div>
            <div class="timeline-loc">Memphis Art Museum — please be seated by 12:50</div>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-time">1:00</div>
          <div class="timeline-diamond"></div>
          <div>
            <div class="timeline-event">Ceremony</div>
            <div class="timeline-loc">River Window</div>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-time">1:30</div>
          <div class="timeline-diamond"></div>
          <div>
            <div class="timeline-event">Cocktail Hour</div>
            <div class="timeline-loc">Roof Terrace — Galleries Open</div>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-time">2:00</div>
          <div class="timeline-diamond"></div>
          <div>
            <div class="timeline-event">Reception &amp; Dinner</div>
            <div class="timeline-loc">Roof Terrace</div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
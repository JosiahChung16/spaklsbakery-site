---
import Layout from '../layouts/Layout.astro';
---

<Layout title="FAQ">
  <section class="page-header">
    <div class="container">
      <span class="section-label">Good to Know</span>
      <h1>Frequently Asked Questions</h1>
      <div class="divider">
        <div class="divider-line"></div>
        <div class="divider-diamond"></div>
        <div class="divider-line"></div>
      </div>
      <p class="header-sub">Can't find your answer here? Don't hesitate to reach out directly.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">

      <!-- THE DAY -->
      <div class="faq-group">
        <span class="section-label">The Day</span>
        <h3 class="faq-group-title">Day-Of Details</h3>
        <div class="faq-list">
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">What time should I arrive?<span class="faq-icon">+</span></button>
            <div class="faq-answer"><p>Please arrive atleast by 4:30.</p></div>
          </div>
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">Where exactly is the venue?<span class="faq-icon">+</span></button>
            <div class="faq-answer"><p>49 S Front St, Memphis, TN 38103</p></div>
          </div>
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">Is the ceremony indoors or outdoors?<span class="faq-icon">+</span></button>
            <div class="faq-answer"><p>The ceremony will be outdoors but in a covered area.</p></div>
          </div>
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">Will there be parking available?<span class="faq-icon">+</span></button>
            <div class="faq-answer"><p>Yes, complimentary parking is available on-site in a parking garage below the museum. But we also encourage carpooling as there is a limited amount of spots in the garage.</p></div>
          </div>
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">Can I take photos during the ceremony?<span class="faq-icon">+</span></button>
            <div class="faq-answer"><p>We are having an unplugged ceremony — we kindly ask that all phones and cameras be put away so that everyone can be fully present. Our photographer will capture every moment. Feel free to take as many photos as you'd like during the reception!</p></div>
          </div>
        </div>
      </div>

      <!-- RSVP & GUESTS -->
      <div class="faq-group">
        <span class="section-label">RSVPs &amp; Guests</span>
        <h3 class="faq-group-title">Attendance</h3>
        <div class="faq-list">
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">When is the RSVP deadline?<span class="faq-icon">+</span></button>
            <div class="faq-answer"><p>Please RSVP no later than October 15th, 2026 using the code printed on your invitation.</p></div>
          </div>
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">Can I bring a plus one?<span class="faq-icon">+</span></button>
            <div class="faq-answer"><p>Due to venue capacity, we are only able to accommodate guests who are listed on the invitation. Your invitation will specify whether a plus one has been included. If you have questions, please reach out directly.</p></div>
          </div>
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">Are children welcome?<span class="faq-icon">+</span></button>
            <div class="faq-answer"><p>Out of respect for our venue's capacity, attendance is strictly limited to those named individually on the invitation. This means we are unable to accommodate additional children unless they were specifically named on your invitation. We hope this gives parents a lovely evening to relax and celebrate with us.</p></div>
          </div>
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">I need to change my RSVP — what do I do?<span class="faq-icon">+</span></button>
            <div class="faq-answer"><p>No problem at all! Simply return to the RSVP page on this site and log in with your invitation code to update your response, or send us an email directly and we'll update it for you.</p></div>
          </div>
        </div>
      </div>

      <!-- FOOD & DRINK -->
      <div class="faq-group">
        <span class="section-label">Food &amp; Drink</span>
        <h3 class="faq-group-title">Dining</h3>
        <div class="faq-list">
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">What kind of food will be served?<span class="faq-icon">+</span></button>
            <div class="faq-answer"><p>Because Memphis is known for their barbecue, we hope to serve this at the wedding. There will also be vegetarian options available. </p></div>
          </div>
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">I have dietary restrictions — can you accommodate me?<span class="faq-icon">+</span></button>
            <div class="faq-answer"><p>Absolutely. There is a field in the RSVP form for dietary notes — please let us know about any allergies or restrictions and we will do our best to accommodate you.</p></div>
          </div>
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">Will there be an open bar?<span class="faq-icon">+</span></button>
            <div class="faq-answer"><p>This is going to be a non-alcoholic wedding, but a coffee/tea bar will be open.</p></div>
          </div>
        </div>
      </div>

      <!-- TRAVEL & STAY -->
      <div class="faq-group">
        <span class="section-label">Travel &amp; Stay</span>
        <h3 class="faq-group-title">Getting Here</h3>
        <div class="faq-list">
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">Are there hotels nearby?<span class="faq-icon">+</span></button>
            <div class="faq-answer"><p>Yes — we have recommended accommodations on the Travel page.</p></div>
          </div>
        </div>
      </div>

      <!-- THE SPAKL STORY -->
      <div class="faq-group spakl-group">
        <span class="section-label">A Little About Us</span>
        <h3 class="faq-group-title">What Does "Spakl" Mean?</h3>
        <div class="faq-list">
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">Why is the domain called spaklsbakery.org?<span class="faq-icon">+</span></button>
            <div class="faq-answer">
              <p>It's a bit of a love story in its own right. When Sarah was in her graduate program, her university email was shortened to <strong>spak</strong> — but since that username was already taken, it became <strong>spak1</strong>. The nickname stuck, and over time it evolved into <em>Spackle</em>, because spak1 looked close enough to make it funny.</p>
              <p>Josiah, on the other hand, has gone by <strong>Cake</strong> online for as long as anyone can remember. So when it came time to give everything a home — the website, a Minecraft server, assorted projects — it only made sense to call it a <em>bakery</em>. After all, where else do you keep a cake?</p>
              <p>The domain was originally Sarah's, but it quietly became the home for both of us — which, looking back, feels just right.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- WES ANDERSON THEME -->
      <div class="faq-group wes-group">
        <span class="section-label">The Wedding Colors</span>
        <h3 class="faq-group-title">About Our Theme</h3>
        <div class="faq-list">
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">Why is the wedding inspired by Wes Anderson?<span class="faq-icon">+</span></button>
            <div class="faq-answer"><p>Wes Anderson is one of our favourite directors — known for his deeply precise, symmetrical, and utterly distinctive films. His worlds feel like beautifully curated storybooks: whimsical yet melancholic, detailed yet warm. We wanted our wedding to feel the same way — like stepping into a world that is entirely its own, where every detail is intentional and every colour means something.</p></div>
          </div>
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">Where does the colour palette come from specifically?<span class="faq-icon">+</span></button>
            <div class="faq-answer"><p>Our palette is drawn from the <em>Swan theme</em>, inspired by the soft botanical tones Anderson uses to evoke nostalgia and quiet beauty. Rather than his bolder, more saturated films like The Grand Budapest Hotel, we leaned into his gentler, more earthy register.</p></div>
          </div>
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">What makes Wes Anderson's use of colour so distinctive?<span class="faq-icon">+</span></button>
            <div class="faq-answer">
              <p>Anderson treats each film frame like a painting. He typically applies the <strong>60-30-10 rule</strong> — 60% dominant base colour, 30% supporting colour, and 10% bold accent — to create visual harmony without overwhelming the eye. Each of his films has its own unmistakable palette: the vivid pinks of <em>The Grand Budapest Hotel</em>, the warm oranges of <em>Fantastic Mr. Fox</em>, the muted yellows of <em>Moonrise Kingdom</em>.</p>
              <p>What makes it truly remarkable is that his colour choices carry emotion. He often places bright, cheerful colours in melancholic scenes, quietly subverting how we feel without us quite knowing why.</p>
            </div>
          </div>
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">Is there more to his style than just colour?<span class="faq-icon">+</span></button>
            <div class="faq-answer">
              <p>Very much so. Anderson is obsessed with <strong>perfect symmetry</strong> — nearly every frame is mathematically balanced, giving his films a sense of surreal order. He uses meticulous typography, handcrafted props, deadpan humour, and a recurring ensemble of collaborators who feel like a repertory theatre company.</p>
              <p>His films exist in a heightened reality: realistic enough to feel true, fantastical enough to feel like a dream. That tension is exactly what we wanted for our wedding day.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- CLOSING CTA -->
      <div class="faq-cta">
        <div class="divider">
          <div class="divider-line"></div>
          <div class="divider-diamond"></div>
          <div class="divider-line"></div>
        </div>
        <p>Still have a question? We'd love to hear from you.</p>
        <a href="mailto:JosiahChung16@gmail.com" class="btn">Send Us a Message</a>
      </div>

    </div>
  </section>
</Layout>

<style>
  .faq-group { max-width: 680px; margin: 0 auto 3rem; }
  .faq-group:last-of-type { margin-bottom: 0; }
  .faq-group-title {
    font-size: 1.5rem;
    color: var(--swan-forest);
    margin-bottom: 1rem;
    margin-top: 0.2rem;
  }

  .faq-list { margin: 0; }
  .faq-item { border-bottom: 1px solid var(--swan-sand); }
  .faq-item:first-of-type { border-top: 1px solid var(--swan-sand); }

  .faq-question {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.1rem 0;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    font-family: var(--font-body);
    font-size: 0.92rem;
    font-weight: 400;
    color: var(--swan-forest);
    letter-spacing: 0.03em;
    gap: 1rem;
    transition: color 0.2s;
  }
  .faq-question:hover { color: var(--swan-olive); }
  .faq-question[aria-expanded="true"] { color: var(--swan-olive); }

  .faq-icon {
    font-size: 1.3rem;
    font-weight: 300;
    color: var(--swan-blush);
    flex-shrink: 0;
    transition: transform 0.2s;
    line-height: 1;
  }
  .faq-question[aria-expanded="true"] .faq-icon { transform: rotate(45deg); }

  .faq-answer { display: none; padding: 0 0 1.2rem; }
  .faq-answer.open { display: block; }
  .faq-answer p {
    font-size: 0.92rem;
    color: var(--swan-brown);
    line-height: 1.8;
    margin-bottom: 1rem;
  }
  .faq-answer p:last-child { margin-bottom: 0; }
  .faq-answer p strong { color: var(--swan-forest); font-weight: 500; }
  .faq-answer p em { color: var(--swan-olive); font-style: italic; }

  .spakl-group {
    background: var(--swan-cream);
    border: 1px solid var(--swan-sand);
    padding: 2rem;
  }
  .spakl-group .faq-item { border-color: rgba(200,190,140,0.5); }
  .spakl-group .faq-item:first-of-type { border-top: none; }
  .spakl-group .faq-item:last-of-type { border-bottom: none; }

  .wes-group {
    background: var(--swan-forest);
    border: 1px solid var(--swan-forest);
    padding: 2rem;
  }
  .wes-group .faq-group-title { color: var(--swan-cream); }
  .wes-group .section-label { color: var(--swan-sage); }
  .wes-group .faq-item { border-color: rgba(234,236,197,0.15); }
  .wes-group .faq-item:first-of-type { border-top: none; }
  .wes-group .faq-item:last-of-type { border-bottom: none; }
  .wes-group .faq-question { color: var(--swan-cream); }
  .wes-group .faq-question:hover { color: var(--swan-sage); }
  .wes-group .faq-question[aria-expanded="true"] { color: var(--swan-sage); }
  .wes-group .faq-icon { color: var(--swan-blush); }
  .wes-group .faq-answer p { color: var(--swan-sand); }
  .wes-group .faq-answer p strong { color: var(--swan-cream); }
  .wes-group .faq-answer p em { color: var(--swan-sage); }

  .faq-cta {
    text-align: center;
    margin-top: 4rem;
    color: var(--swan-brown);
    font-size: 0.95rem;
  }
  .faq-cta p { margin-bottom: 1.2rem; }
</style>

<script>
  const questions = document.querySelectorAll('.faq-question');

  questions.forEach((btn) => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      const answer = btn.nextElementSibling as HTMLElement;

      questions.forEach((other) => {
        other.setAttribute('aria-expanded', 'false');
        const otherAnswer = other.nextElementSibling as HTMLElement;
        if (otherAnswer) otherAnswer.classList.remove('open');
      });

      if (!expanded) {
        btn.setAttribute('aria-expanded', 'true');
        answer.classList.add('open');
      }
    });
  });
</script>
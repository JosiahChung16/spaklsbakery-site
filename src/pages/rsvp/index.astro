---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="RSVP">
  <section class="page-header">
    <div class="container">
      <span class="section-label">You're Invited</span>
      <h1>Confirm Your Attendance</h1>
      <div class="divider">
        <div class="divider-line"></div>
        <div class="divider-diamond"></div>
        <div class="divider-line"></div>
      </div>
      <p class="header-sub">Enter the invitation code from your invitation email to access your RSVP.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="rsvp-entry-wrap">

        <div class="entry-card" id="entryCard">
          <span class="section-label">Step One</span>
          <h2>Enter Your Code</h2>

          <form class="entry-form" id="entryForm">
            <div class="form-group">
              <label class="form-label" for="inviteCode">Invitation Code</label>
              <input
                class="form-input"
                type="text"
                id="inviteCode"
                name="inviteCode"
                placeholder="e.g. Robin"
                autocomplete="off"
                autocapitalize="characters"
                required
              />
            </div>

            <div class="error-msg" id="errorMsg"></div>

            <button type="submit" class="btn btn-filled" id="submitBtn">
              Access My Invitation
            </button>
          </form>

          <div class="forgot-link">
            <a href="mailto:JosiahChung16@gmail.com?subject=Wedding Invitation Code Request">
              Misplaced your code? Email us.
            </a>
          </div>
        </div>

        <div class="attempts-note">
          <span class="section-label">Having trouble?</span>
          <p>Your invitation code was included in the invitation email we sent you. Everyone in your household shares the same code, so any family member can log in to view or update your household's response. If you continue to have trouble, please reach out directly.</p>
        </div>

      </div>
    </div>
  </section>
</Layout>

<script>
  const FUNCTION_URL = `${import.meta.env.PUBLIC_SUPABASE_URL}/functions/v1/validate-invite`;
  const ANON_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

  const form = document.getElementById('entryForm') as HTMLFormElement;
  const errorMsg = document.getElementById('errorMsg') as HTMLDivElement;
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;

  if (sessionStorage.getItem('wedding_session')) {
    window.location.href = '/rsvp/confirm';
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorMsg.classList.remove('visible');

    const inviteCode = (document.getElementById('inviteCode') as HTMLInputElement).value.trim();

    submitBtn.textContent = 'Checking...';
    submitBtn.disabled = true;

    try {
      const res = await fetch(FUNCTION_URL, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${ANON_KEY}`,
        },
        body: JSON.stringify({ invite_code: inviteCode }),
      });

      const data = await res.json();

      if (!res.ok || data.error) {
        errorMsg.textContent = data.error || 'That code was not found. Please try again.';
        errorMsg.classList.add('visible');
        submitBtn.textContent = 'Access My Invitation';
        submitBtn.disabled = false;
        return;
      }

      // Store the code + loaded household/guests for the confirm page
      sessionStorage.setItem('wedding_session', JSON.stringify({
        invite_code: inviteCode,
        household: data.household,
        guests: data.guests,
      }));
      window.location.href = '/rsvp/confirm';

    } catch (_err) {
      errorMsg.textContent = 'Something went wrong. Please check your connection and try again.';
      errorMsg.classList.add('visible');
      submitBtn.textContent = 'Access My Invitation';
      submitBtn.disabled = false;
    }
  });
</script>
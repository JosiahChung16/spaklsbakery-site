---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="RSVP">
  <section class="page-header">
    <div class="container">
      <span class="section-label">You're Invited</span>
      <h1>Confirm Your Attendance</h1>
      <div class="divider">
        <div class="divider-line"></div>
        <div class="divider-diamond"></div>
        <div class="divider-line"></div>
      </div>
      <p class="header-sub">Enter your last name and the invitation code printed on your envelope to access your RSVP.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="rsvp-entry-wrap">

        <div class="entry-card" id="entryCard">
          <span class="section-label">Step One</span>
          <h2>Locate Your Invitation</h2>

          <form class="entry-form" id="entryForm">
            <div class="form-group">
              <label class="form-label" for="lastName">Last Name</label>
              <input
                class="form-input"
                type="text"
                id="lastName"
                name="lastName"
                placeholder="e.g. Whitmore"
                autocomplete="family-name"
                required
              />
            </div>

            <div class="form-group">
              <label class="form-label" for="inviteCode">Invitation Code</label>
              <input
                class="form-input"
                type="text"
                id="inviteCode"
                name="inviteCode"
                placeholder="e.g. WHI-4829"
                autocomplete="off"
                required
              />
            </div>

            <div class="error-msg" id="errorMsg"></div>

            <button type="submit" class="btn btn-filled" id="submitBtn">
              Access My Invitation
            </button>
          </form>

          <div class="forgot-link">
            <a href="mailto:youremail@email.com?subject=Wedding Invitation Code Request">
              Misplaced your code? Email us.
            </a>
          </div>
        </div>

        <div class="attempts-note">
          <span class="section-label">Having trouble?</span>
          <p>Your code was printed on the back of your invitation envelope. It follows the format: first three letters of your last name followed by four digits (e.g. WHI-4829). If you continue to have trouble please reach out directly.</p>
        </div>

      </div>
    </div>
  </section>
</Layout>

<style>
  .header-sub {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.1rem;
    color: var(--swan-brown);
    max-width: 500px;
    margin: 0.8rem auto 0;
  }

  .rsvp-entry-wrap {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 5rem;
    align-items: start;
    max-width: 820px;
    margin: 0 auto;
  }

  .entry-card {
    background: var(--swan-white);
    border: 1px solid var(--swan-sand);
    padding: 2.5rem;
  }
  .entry-card h2 { margin-bottom: 1.5rem; }

  .entry-form { display: flex; flex-direction: column; gap: 0; }

  .error-msg {
    display: none;
    background: #f8e8e8;
    border: 1px solid #d4a0a0;
    padding: 0.75rem 1rem;
    font-size: 0.85rem;
    color: #8b3a3a;
    margin-bottom: 1rem;
    line-height: 1.5;
  }
  .error-msg.visible { display: block; }

  .btn { width: 100%; text-align: center; }

  .forgot-link {
    margin-top: 1rem;
    text-align: center;
    font-size: 0.78rem;
    font-style: italic;
    color: var(--swan-brown);
  }
  .forgot-link a { color: var(--swan-olive); }

  .attempts-note { padding-top: 0.5rem; }
  .attempts-note p {
    font-size: 0.85rem;
    color: var(--swan-brown);
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .rsvp-entry-wrap { grid-template-columns: 1fr; gap: 2.5rem; }
  }
</style>

<script>
  import { createClient } from '@supabase/supabase-js';

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  );

  const form = document.getElementById('entryForm') as HTMLFormElement;
  const errorMsg = document.getElementById('errorMsg') as HTMLDivElement;
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;

  const existingGuest = sessionStorage.getItem('wedding_guest');
  if (existingGuest) {
    window.location.href = '/rsvp/confirm';
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorMsg.classList.remove('visible');

    const lastName = (document.getElementById('lastName') as HTMLInputElement).value.trim();
    const inviteCode = (document.getElementById('inviteCode') as HTMLInputElement).value.trim();

    submitBtn.textContent = 'Checking...';
    submitBtn.disabled = true;

    const { data, error } = await supabase
      .from('invitations')
      .select('*')
      .ilike('last_name', lastName)
      .ilike('invite_code', inviteCode)
      .single();

    if (error || !data) {
      errorMsg.textContent = 'Invalid name or code. Please try again.';
      errorMsg.classList.add('visible');
      submitBtn.textContent = 'Access My Invitation';
      submitBtn.disabled = false;
      return;
    }

    sessionStorage.setItem('wedding_guest', JSON.stringify(data));
    window.location.href = '/rsvp/confirm';
  });
</script>
---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="RSVP">
  <section class="page-header">
    <div class="container">
      <span class="section-label">You're Invited</span>
      <h1>Confirm Your Attendance</h1>
      <div class="divider">
        <div class="divider-line"></div>
        <div class="divider-diamond"></div>
        <div class="divider-line"></div>
      </div>
      <p class="header-sub">Enter your last name and the invitation code from your invitation email to access your RSVP.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="rsvp-entry-wrap">

        <div class="entry-card" id="entryCard">
          <span class="section-label">Step One</span>
          <h2>Locate Your Invitation</h2>

          <form class="entry-form" id="entryForm">
            <div class="form-group">
              <label class="form-label" for="lastName">Last Name</label>
              <input
                class="form-input"
                type="text"
                id="lastName"
                name="lastName"
                placeholder="e.g. Whitmore"
                autocomplete="family-name"
                required
              />
            </div>

            <div class="form-group">
              <label class="form-label" for="inviteCode">Invitation Code</label>
              <input
                class="form-input"
                type="text"
                id="inviteCode"
                name="inviteCode"
                placeholder="e.g. WHI-4829"
                autocomplete="off"
                required
              />
            </div>

            <div class="error-msg" id="errorMsg"></div>

            <button type="submit" class="btn btn-filled" id="submitBtn">
              Access My Invitation
            </button>
          </form>

          <div class="forgot-link">
            <a href="mailto:JosiahChung16@gmail.com?subject=Wedding Invitation Code Request">
              Misplaced your code? Email us.
            </a>
          </div>
        </div>

        <div class="attempts-note">
          <span class="section-label">Having trouble?</span>
          <p>Your last name and invitation code were included in the invitation email we sent you. Everyone invited from your household will appear once you log in, so you can reply for your whole family in one place. If you continue to have trouble, please reach out directly.</p>
        </div>

      </div>
    </div>
  </section>
</Layout>

<script>
  import { createClient } from '@supabase/supabase-js';

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  );

  const form = document.getElementById('entryForm') as HTMLFormElement;
  const errorMsg = document.getElementById('errorMsg') as HTMLDivElement;
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;

  const existingGuest = sessionStorage.getItem('wedding_invitation');
  if (existingGuest) {
    window.location.href = '/rsvp/confirm';
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorMsg.classList.remove('visible');

    const lastName = (document.getElementById('lastName') as HTMLInputElement).value.trim();
    const inviteCode = (document.getElementById('inviteCode') as HTMLInputElement).value.trim();

    submitBtn.textContent = 'Checking...';
    submitBtn.disabled = true;

    const { data, error } = await supabase
      .from('invitations')
      .select('id, last_name, invite_code, email')
      .ilike('last_name', lastName)
      .ilike('invite_code', inviteCode)
      .single();

    if (error || !data) {
      errorMsg.textContent = 'Invalid name or code. Please try again.';
      errorMsg.classList.add('visible');
      submitBtn.textContent = 'Access My Invitation';
      submitBtn.disabled = false;
      return;
    }

    sessionStorage.setItem('wedding_invitation', JSON.stringify(data));
    window.location.href = '/rsvp/confirm';
  });
</script>
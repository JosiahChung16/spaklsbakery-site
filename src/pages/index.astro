---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Front Page" section="Today's Edition" sectionNote="Special Nuptial Supplement · March 7, 2027">

  <!-- ── THREE-COLUMN LEAD ── -->
  <section class="fd-lead">
    <div class="fd-lead-inner">

      <!-- LEFT COLUMN — How they met -->
      <article class="fd-col-left">
        <span class="kicker">Local Affairs</span>
        <h3 class="col-head">An Account of How They Met, and Why It Matters</h3>
        <div class="byline">By Our Correspondent · Memphis Bureau</div>
        <p class="col-body drop-cap">
          It began, as so many things in this city do, with a borrowed umbrella, a missed train, and a friendly disagreement about a record neither party had finished listening to. Neither had intended to make a fuss. Both, in the end, did.
        </p>
        <div class="pull-quote">
          "She said yes before he had finished the question. He had not, in truth, finished the question."
        </div>
        <p class="col-body">
          They have since agreed, in broad terms, on most things. Minor disputes — the kitchen clock, the bookshelves, the correct way to cut a tomato — remain formally unresolved, and are not expected to be resolved soon.
        </p>

        <div class="mini-sub">
          <span class="kicker">A Footnote</span>
          <h4 class="col-subhead">On the Affair Itself</h4>
          <p class="col-body">
            The ceremony will be held on the rooftop, weather permitting, and indoors if it is not. A reception of indeterminate length will follow. Guests are encouraged to stay for the dancing, which is anticipated to be of variable quality.
          </p>
        </div>
      </article>

      <div class="col-rule"></div>

      <!-- CENTER COLUMN — Main announcement -->
      <article class="fd-col-center">
        <div class="fd-headline-eyebrow">A Marriage Announcement</div>
        <h1 class="fd-headline-main">
          Two Memphians<br/>
          <em>Announce Marriage</em><br/>
          at the Museum
        </h1>
        <div class="deck">
          A ceremony on the rooftop, followed by dinner, speeches of variable length, and dancing of uncertain quality
        </div>

        <div class="fd-illus">
          <svg viewBox="0 0 280 280" xmlns="http://www.w3.org/2000/svg" class="fd-seal" aria-hidden="true">
            <!-- Outer rings -->
            <circle cx="140" cy="140" r="132" fill="none" stroke="#111010" stroke-width="2"/>
            <circle cx="140" cy="140" r="124" fill="none" stroke="#111010" stroke-width="0.5"/>
            <circle cx="140" cy="140" r="82"  fill="none" stroke="#111010" stroke-width="1.2"/>

            <!-- Curved text -->
            <defs>
              <path id="arc-top" d="M 30 140 A 110 110 0 0 1 250 140"/>
              <path id="arc-bot" d="M 30 140 A 110 110 0 0 0 250 140"/>
            </defs>
            <text font-family="Libre Baskerville, serif" font-size="13" font-weight="700" letter-spacing="4" fill="#111010">
              <textPath href="#arc-top" startOffset="50%" text-anchor="middle">JOSIAH AND SARAH</textPath>
            </text>
            <text font-family="Libre Baskerville, serif" font-size="11" font-weight="700" letter-spacing="6" fill="#111010">
              <textPath href="#arc-bot" startOffset="50%" text-anchor="middle">MEMPHIS · MMXXVII</textPath>
            </text>

            <!-- Side ornaments (red diamonds) -->
            <rect x="-4" y="-4" width="8" height="8" fill="#B5141A" transform="translate(37 140) rotate(45)"/>
            <rect x="-4" y="-4" width="8" height="8" fill="#B5141A" transform="translate(243 140) rotate(45)"/>

            <!-- Center monogram -->
            <text x="103" y="160" font-family="Playfair Display, Georgia, serif" font-weight="900" font-size="60" fill="#111010">J</text>
            <text x="140" y="172" font-family="Playfair Display, Georgia, serif" font-style="italic" font-size="44" fill="#B5141A" text-anchor="middle">&amp;</text>
            <text x="158" y="160" font-family="Playfair Display, Georgia, serif" font-weight="900" font-size="60" fill="#111010">S</text>

            <!-- Top/bottom flourishes -->
            <text x="140" y="80" text-anchor="middle" font-size="18" fill="#B5141A">✦</text>
            <text x="140" y="212" text-anchor="middle" font-family="Libre Baskerville, serif" font-style="italic" font-size="10" fill="#6B6458">— sealed —</text>
          </svg>
        </div>

        <div class="fd-meta-row">
          <div class="fd-meta-item">
            <div class="fd-meta-key">Date</div>
            <div class="fd-meta-val">Sunday, March 7</div>
          </div>
          <div class="fd-meta-divider"></div>
          <div class="fd-meta-item">
            <div class="fd-meta-key">Venue</div>
            <div class="fd-meta-val">Memphis Art Museum</div>
          </div>
          <div class="fd-meta-divider"></div>
          <div class="fd-meta-item">
            <div class="fd-meta-key">Year</div>
            <div class="fd-meta-val">MMXXVII</div>
          </div>
        </div>

        <div class="fd-cta-row">
          <a href="/rsvp" class="btn btn-filled">Confirm Attendance</a>
          <a href="/schedule" class="btn">View Programme</a>
        </div>
      </article>

      <div class="col-rule"></div>

      <!-- RIGHT COLUMN — Programme -->
      <aside class="fd-col-right">
        <span class="kicker">Programme</span>
        <h3 class="col-head">Order of the Day</h3>
        <div class="byline">Roof Top &amp; Gallery · March 7</div>

        <ul class="fd-programme">
          <li>
            <span class="prog-time">12:30</span>
            <div>
              <div class="prog-title">The Ceremony</div>
              <div class="prog-sub">The Roof Top</div>
            </div>
          </li>
          <li>
            <span class="prog-time">1:30</span>
            <div>
              <div class="prog-title">Cocktail Hour</div>
              <div class="prog-sub">Gallery &amp; River Window</div>
            </div>
          </li>
          <li>
            <span class="prog-time">2:00</span>
            <div>
              <div class="prog-title">The Reception</div>
              <div class="prog-sub">The Roof Top</div>
            </div>
          </li>
        </ul>

        <div class="fd-dresscode">
          <span class="kicker">Dress</span>
          <div class="prog-title">Formal</div>
          <p class="dresscode-note"><em>Soft tones and florals warmly welcomed. Black, ivory, and white kindly discouraged.</em></p>
        </div>

        <div class="fd-stamp-wrap">
          <span class="rubber-stamp">Reply by Jan 1</span>
        </div>
      </aside>

    </div>
  </section>

  <!-- ── PULL QUOTE BAND ── -->
  <section class="fd-quote-band">
    <div class="container">
      <div class="quote-marks">"</div>
      <p class="big-quote">
        A marriage, recorded and reported here with particular care, in the presence of those who have known the parties longest and forgiven them most.
      </p>
      <div class="quote-attrib">— from the editor's note</div>
    </div>
  </section>

  <!-- ── BOTTOM STRIP: three editorial cards ── -->
  <section class="fd-bottom-strip">
    <div class="fd-bottom-rule"></div>
    <div class="fd-bottom-inner">

      <a href="/registry" class="bs-card">
        <span class="kicker">On the Registry</span>
        <h4 class="bs-head">Household &amp; Sundries</h4>
        <p class="bs-body">A modest selection of household items, books, and one rather expensive lamp has been noted at the usual establishments. Contributions of any kind are received with gratitude.</p>
        <span class="bs-more">Consult the list →</span>
      </a>

      <div class="bs-rule"></div>

      <a href="/travel" class="bs-card">
        <span class="kicker">Getting There</span>
        <h4 class="bs-head">Travel &amp; Lodging</h4>
        <p class="bs-body">Rooms have been reserved at several inns of varying character. Out-of-town guests are encouraged to book early, as the city receives travellers with enthusiasm.</p>
        <span class="bs-more">Practical notes →</span>
      </a>

      <div class="bs-rule"></div>

      <a href="/attire" class="bs-card">
        <span class="kicker">Dress Notes</span>
        <h4 class="bs-head">A Note on Attire</h4>
        <div class="bs-palette">
          <span style="background:#A6D0C8"></span>
          <span style="background:#C8B44A"></span>
          <span style="background:#A65852"></span>
          <span style="background:#2C7C94"></span>
          <span style="background:#FBE45B"></span>
          <span style="background:#C4AA23"></span>
        </div>
        <p class="bs-body">Soft tones and florals are encouraged in the spirit of the season. Comfortable shoes are advised; the rooftop is exposed to the prevailing breezes.</p>
        <span class="bs-more">Full guidance →</span>
      </a>

    </div>
    <div class="fd-bottom-rule"></div>
  </section>

</Layout>

<style>
  /* ── LEAD SECTION ── */
  .fd-lead {
    padding: 2rem 0 1rem;
  }
  .fd-lead-inner {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: grid;
    grid-template-columns: 1fr 1px 1.35fr 1px 1fr;
    gap: 1.6rem;
    align-items: stretch;
  }

  /* Column headings */
  .col-head {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.25rem;
    line-height: 1.2;
    margin-bottom: 0.4rem;
  }
  .col-subhead {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.05rem;
    line-height: 1.25;
    margin-bottom: 0.3rem;
  }
  .mini-sub {
    margin-top: 1.4rem;
    padding-top: 1rem;
    border-top: 0.5px solid var(--fd-black);
  }

  /* CENTER */
  .fd-col-center { text-align: center; }
  .fd-headline-eyebrow {
    font-family: var(--font-italic);
    font-style: italic;
    font-size: 0.95rem;
    color: var(--fd-red);
    margin-bottom: 0.4rem;
  }
  .fd-headline-main {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(2.4rem, 4.5vw, 3.6rem);
    line-height: 1.02;
    color: var(--fd-black);
    letter-spacing: -0.01em;
    margin-bottom: 0.4rem;
  }
  .fd-headline-main em {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    color: var(--fd-red);
  }

  /* SEAL */
  .fd-illus {
    display: flex;
    justify-content: center;
    margin: 1rem 0 1.2rem;
  }
  .fd-seal {
    width: 240px;
    height: 240px;
    max-width: 75%;
  }

  /* Meta row */
  .fd-meta-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    border-top: 0.5px solid var(--fd-black);
    border-bottom: 0.5px solid var(--fd-black);
    padding: 10px 0;
    margin-bottom: 1.4rem;
  }
  .fd-meta-item { text-align: center; flex: 1; }
  .fd-meta-key {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--fd-red);
    margin-bottom: 2px;
  }
  .fd-meta-val {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.95rem;
    color: var(--fd-black);
  }
  .fd-meta-divider {
    width: 1px;
    height: 28px;
    background: var(--fd-black);
  }

  .fd-cta-row {
    display: flex;
    gap: 0.8rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* RIGHT — Programme */
  .fd-programme {
    list-style: none;
    margin-bottom: 1.4rem;
  }
  .fd-programme li {
    display: flex;
    gap: 0.8rem;
    padding: 0.6rem 0;
    border-bottom: 0.5px dotted var(--fd-black);
  }
  .fd-programme li:last-child { border-bottom: none; }
  .prog-time {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.4rem;
    color: var(--fd-black);
    min-width: 50px;
    line-height: 1;
  }
  .prog-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    color: var(--fd-black);
    line-height: 1.2;
  }
  .prog-sub {
    font-family: var(--font-italic);
    font-style: italic;
    font-size: 0.82rem;
    color: var(--fd-gray);
  }

  .fd-dresscode {
    border-top: 1.5px solid var(--fd-black);
    border-bottom: 1.5px solid var(--fd-black);
    padding: 0.8rem 0;
    margin-bottom: 1.4rem;
    text-align: left;
  }
  .dresscode-note {
    font-size: 0.82rem;
    color: var(--fd-gray);
    margin-top: 0.3rem;
  }

  .fd-stamp-wrap { text-align: center; margin-top: 1rem; }

  /* ── PULL QUOTE BAND ── */
  .fd-quote-band {
    background: var(--fd-black);
    color: var(--fd-cream);
    padding: 3rem 1.5rem;
    text-align: center;
    margin: 1.5rem 0 0;
  }
  .fd-quote-band .container { max-width: 760px; }
  .quote-marks {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 4rem;
    line-height: 0.5;
    color: var(--fd-red);
    margin-bottom: 0.8rem;
  }
  .big-quote {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.2rem, 2.4vw, 1.8rem);
    line-height: 1.4;
    color: var(--fd-cream);
    margin-bottom: 1rem;
  }
  .quote-attrib {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--fd-tan);
  }

  /* ── BOTTOM STRIP ── */
  .fd-bottom-strip { padding: 0 1.5rem; margin-top: 2rem; }
  .fd-bottom-rule {
    max-width: 1080px;
    margin: 0 auto;
    border-top: 3px double var(--fd-black);
    height: 0;
  }
  .fd-bottom-inner {
    max-width: 1080px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1px 1fr 1px 1fr;
    gap: 1.4rem;
    padding: 1.8rem 0;
  }
  .bs-rule { background: var(--fd-black); width: 1px; }
  .bs-card {
    display: block;
    text-decoration: none;
    color: var(--fd-black);
    border: none;
    transition: opacity 0.15s;
  }
  .bs-card:hover { opacity: 0.7; color: var(--fd-black); }
  .bs-head {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.15rem;
    color: var(--fd-black);
    margin-bottom: 0.5rem;
    line-height: 1.2;
  }
  .bs-body {
    font-family: var(--font-italic);
    font-style: italic;
    font-size: 0.88rem;
    color: var(--fd-gray);
    line-height: 1.55;
    margin-bottom: 0.6rem;
  }
  .bs-more {
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--fd-red);
  }
  .bs-palette {
    display: flex;
    gap: 4px;
    margin-bottom: 0.7rem;
  }
  .bs-palette span {
    flex: 1;
    height: 14px;
    border: 0.5px solid var(--fd-black);
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 860px) {
    .fd-lead-inner {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .fd-lead-inner .col-rule {
      width: 100%;
      height: 1px;
    }
    .fd-bottom-inner {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .fd-bottom-inner .bs-rule {
      width: 100%;
      height: 1px;
    }
    .fd-meta-row {
      flex-wrap: wrap;
      gap: 0.5rem;
    }
    .fd-meta-divider { display: none; }
  }
</style>